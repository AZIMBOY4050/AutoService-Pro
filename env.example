# Server
HOST=127.0.0.1
PORT=3000

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=autoservice_booking
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/autoservice_booking
DB_SSL=false

# Auth
JWT_SECRET=replace-with-a-long-random-jwt-secret
JWT_EXPIRES_IN=7d

# Frontend origin(s), comma-separated when needed
CORS_ORIGIN=http://127.0.0.1:3000,http://localhost:3000

# Seed admin
ADMIN_FULL_NAME=System Administrator
ADMIN_EMAIL=admin@autoservice.local
ADMIN_PHONE=+998900000000
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Email notifications
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=example-user
SMTP_PASS=example-password
SMTP_FROM=AutoService <no-reply@example.com>
